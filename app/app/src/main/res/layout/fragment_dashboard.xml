<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#F3F4F6"> <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="2dp"
        app:contentPadding="12dp">

        <TextView
            android:id="@+id/tv_device_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🟢 Device Status: Connected"
            android:textAlignment="center"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#388E3C"/>
    </com.google.android.material.card.MaterialCardView>
    <TextView
        android:id="@+id/tv_warmup_warning"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFF3E0"
        android:textColor="#E65100"
        android:text="⏳ Sensors Warming Up... Data may be inaccurate for the first 20 minutes."
        android:padding="12dp"
        android:textSize="14sp"
        android:textStyle="bold"
        android:gravity="center"
        android:visibility="gone"
        android:layout_marginBottom="16dp"
        android:elevation="2dp" />
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="4dp"
        app:contentPadding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="The Air Quality Index around you is:"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#555555"
                android:layout_marginBottom="8dp"/>

            <com.github.anastr.speedviewlib.SpeedView
                android:id="@+id/speedView_local"
                android:layout_width="220dp"
                android:layout_height="220dp"
                app:sv_maxSpeed="10"
                app:sv_withTremble="false"
                app:sv_unit=""
                app:sv_speedometerWidth="40dp" app:sv_tickNumber="11"/>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="4dp"
        app:contentPadding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:id="@+id/tv_city_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AQI from the Goverment"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#555555"
                android:layout_marginBottom="8dp"/>

            <com.github.anastr.speedviewlib.SpeedView
                android:id="@+id/speedView_city"
                android:layout_width="220dp"
                android:layout_height="220dp"
                app:sv_maxSpeed="10"
                app:sv_withTremble="false"
                app:sv_unit=""
                app:sv_speedometerWidth="40dp" app:sv_tickNumber="11"/>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:id="@+id/tv_health_advice"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp"
        android:padding="16dp"
        android:background="#E3F2FD"
        android:text="Analyzing room data..."
        android:textColor="#0277BD"
        android:textSize="15sp"
        android:textStyle="bold"
        android:lineSpacingExtra="4dp" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_trend"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="32dp"
        android:clickable="true"
        android:focusable="true"
        app:cardCornerRadius="16dp"
        app:cardElevation="4dp">

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="AQI Trend (Past Hour)"
                    android:textStyle="bold"
                    android:textColor="#555555"
                    android:layout_marginBottom="8dp"/>

                <com.github.mikephil.charting.charts.LineChart
                    android:id="@+id/lineChart_dashboard_aqi"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </com.google.android.material.card.MaterialCardView>

</LinearLayout>
</androidx.core.widget.NestedScrollView>