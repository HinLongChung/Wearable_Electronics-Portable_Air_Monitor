<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F3F4F6"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Detailed Gas Breakdown"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Live Arduino Sensor Data"
            android:textSize="14sp"
            android:textColor="#888888"
            android:layout_marginBottom="24dp"/>
        <TextView
            android:id="@+id/tv_details_warmup_warning"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FFF3E0"
            android:textColor="#E65100"
            android:text="⏳ Sensors Warming Up... Data may be inaccurate for the first 20 minutes."
            android:padding="12dp"
            android:textSize="14sp"
            android:textStyle="bold"
            android:gravity="center"
            android:visibility="gone"
            android:layout_marginBottom="16dp"
            android:elevation="2dp" />
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:baselineAligned="false"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="NO2 (µg/m³)" android:textStyle="bold"/>
                <com.github.anastr.speedviewlib.SpeedView
                    android:id="@+id/gauge_no2"
                    android:layout_width="140dp"
                    android:layout_height="140dp"
                    app:sv_maxSpeed="600"
                    app:sv_withTremble="false"
                    app:sv_unit=""
                    app:sv_speedometerWidth="20dp"
                    app:sv_textSize="0sp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="SO2 (µg/m³)" android:textStyle="bold"/>
                <com.github.anastr.speedviewlib.SpeedView
                    android:id="@+id/gauge_so2"
                    android:layout_width="140dp"
                    android:layout_height="140dp"
                    app:sv_maxSpeed="1000"
                    app:sv_withTremble="false"
                    app:sv_unit=""
                    app:sv_speedometerWidth="20dp"
                    app:sv_textSize="0sp"/>
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:baselineAligned="false"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="O3 (µg/m³)" android:textStyle="bold"/>
                <com.github.anastr.speedviewlib.SpeedView
                    android:id="@+id/gauge_o3"
                    android:layout_width="140dp"
                    android:layout_height="140dp"
                    app:sv_maxSpeed="400"
                    app:sv_withTremble="false"
                    app:sv_unit=""
                    app:sv_speedometerWidth="20dp"
                    app:sv_textSize="0sp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="PM 2.5 (µg/m³)" android:textStyle="bold"/>
                <com.github.anastr.speedviewlib.SpeedView
                    android:id="@+id/gauge_pm25"
                    android:layout_width="140dp"
                    android:layout_height="140dp"
                    app:sv_maxSpeed="100"
                    app:sv_withTremble="false"
                    app:sv_unit=""
                    app:sv_speedometerWidth="20dp"
                    app:sv_textSize="0sp"/>
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:baselineAligned="false"
            android:layout_marginBottom="32dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="PM 10 (µg/m³)" android:textStyle="bold"/>
                <com.github.anastr.speedviewlib.SpeedView
                    android:id="@+id/gauge_pm10"
                    android:layout_width="140dp"
                    android:layout_height="140dp"
                    app:sv_maxSpeed="150"
                    app:sv_withTremble="false"
                    app:sv_unit=""
                    app:sv_speedometerWidth="20dp"
                    app:sv_textSize="0sp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="CO2 (ppm)" android:textStyle="bold"/>
                <com.github.anastr.speedviewlib.SpeedView
                    android:id="@+id/gauge_co2"
                    android:layout_width="140dp"
                    android:layout_height="140dp"
                    app:sv_maxSpeed="2000"
                    app:sv_withTremble="false"
                    app:sv_unit=""
                    app:sv_speedometerWidth="20dp"
                    app:sv_textSize="0sp"/>
            </LinearLayout>
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_back_to_dash"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="Back to Dashboard"
            android:textSize="18sp"
            app:backgroundTint="#C2185B"/>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>